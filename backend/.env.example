PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1
APP_NAME=ASL Detection API
DEBUG=false
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
LOG_JSON=true
EXPOSE_ERROR_DETAILS=false
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
WEIGHTS_DIR=backend/weights
PREPROCESS_CONFIG_PATH=prepared/preprocess.json
CONFIDENCE_THRESHOLD=0.55
WS_SMOOTHING_WINDOW=8
WS_TARGET_FPS=12
MAX_FRAME_SIZE=640
